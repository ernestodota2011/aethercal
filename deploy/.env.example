# AetherCal self-host configuration — copy to `.env` and fill in. PLACEHOLDERS ONLY, no real
# secrets in this file. Everything the app reads is an AETHERCAL_* variable (RF-19). The POSTGRES_*
# and HOST_PORT values at the bottom are consumed by docker-compose.yml, not by the app itself.

# ============================ Required ============================

# ---------------------------------------------------------------------------
# THREE database URLs, because there are THREE roles. Create them BEFORE the first `up`:
#
#   psql "$SUPERUSER_URL" -v ON_ERROR_STOP=1 -v db=aethercal \
#        -v pw_owner=... -v pw_app=... -v pw_worker=... -f sql/provision_roles.sql
#
# They are three DIFFERENT passwords, and none of them is POSTGRES_PASSWORD below (that is the
# bootstrap superuser the postgres container initialises itself with; the application never uses it).
#
# ==There is deliberately NO fallback between them.== Under row-level security a connection on the
# wrong role does not raise — it reads ZERO rows. A URL that quietly degraded to another role would
# produce a process that boots, works, logs nothing and enforces nothing. So each process asserts
# `SELECT current_user` at boot and REFUSES to start on the wrong answer.
# ---------------------------------------------------------------------------

# `aethercal_app` — the API + the admin (the `app` service). SUBJECT to row-level security: this is
# the identity that must never be able to see another business's rows.
AETHERCAL_DATABASE_URL=postgresql://aethercal_app:CHANGE_ME_APP_PASSWORD@postgres:5432/aethercal

# `aethercal_owner` — Alembic + the admin CLI: the one-shot `migrate` service, and every
# `docker compose exec app aethercal-admin ...`. It OWNS the tables, and carries BYPASSRLS so that
# `guest purge` can still erase a guest under FORCE ROW LEVEL SECURITY.
AETHERCAL_OWNER_DATABASE_URL=postgresql://aethercal_owner:CHANGE_ME_OWNER_PASSWORD@postgres:5432/aethercal

# `aethercal_worker` — the `worker` service's SCAN pool ONLY (BYPASSRLS): finding work whose business
# cannot be known until the row has been read. The worker EXECUTES every effect on the app role
# above, under RLS, bound to that item's own business.
AETHERCAL_WORKER_DATABASE_URL=postgresql://aethercal_worker:CHANGE_ME_WORKER_PASSWORD@postgres:5432/aethercal

# Master secret: signs guest booking tokens AND derives the Fernet key that encrypts stored provider
# credentials. Use a long random value, e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`.
AETHERCAL_APP_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# ============================ Operational toggles ============================

# ==AETHERCAL_RUN_SCHEDULER and AETHERCAL_AUTO_MIGRATE are RETIRED==, and a truthy value now FAILS
# THE BOOT rather than being quietly honoured or quietly ignored. They are absent from this file on
# purpose. Do not re-add them.
#
#   the scheduler → its own process: the `worker` service (`aethercal-worker`), which holds the two
#     pools the work actually needs. The flag never separated anything — it left the API and the
#     admin mounted and bound every tick to the REQUEST path's sessionmaker, which in a background
#     tick carries no business and therefore selects ZERO rows, silently.
#   the migrator  → the one-shot `migrate` service (`aethercal-admin db upgrade`), run as the OWNER.
#     The app holds `aethercal_app`, owns no tables and cannot execute DDL — and migrating inside the
#     web process is exactly what forced the app to BE the table owner, which is exactly what would
#     have made row-level security on this product a placebo.

# How often the scheduler ticks, in seconds. The values below ARE the production defaults — leave
# them alone unless you have a reason. They are knobs so that a test or staging stack can drain its
# outbox and deliver its webhooks in seconds instead of waiting a real minute per effect (the E2E
# stack sets both to 5). Must be > 0: a zero would leave the scheduler ticking wrong, or not at all.
AETHERCAL_OUTBOX_DRAIN_INTERVAL_SECONDS=60
AETHERCAL_WEBHOOK_INTERVAL_SECONDS=60
# The host busy-cache refresh (Google Calendar).
AETHERCAL_BUSY_REFRESH_INTERVAL_SECONDS=300

# Echo every SQL statement to the log (debugging only — noisy). Default off.
AETHERCAL_ECHO_SQL=0

# ---------------------------------------------------------------------------
# Outbound webhooks: which PRIVATE networks may be delivered to (SSRF egress).
# ---------------------------------------------------------------------------
# Blank (the default) = NONE. Every webhook target that is not reachable from the public internet is
# refused, the delivery is parked `dead`, and it is not retried.
#
# That default is wrong for the deployment you are probably in: your n8n / CRM / ERP sits on the same
# Docker network, LAN or VPN as AetherCal, and it will receive NOTHING. Declare the network(s) it
# lives on — explicit CIDRs, comma-separated:
#
#   AETHERCAL_WEBHOOK_PRIVATE_TARGET_CIDRS=192.168.1.0/24,172.17.0.0/16
#
# READ THIS BEFORE SETTING IT. A webhook URL is chosen by whoever creates the subscription; this
# variable decides where those URLs may reach. Every address inside these CIDRs is something a
# subscriber can make this server POST to — including internal services that are unauthenticated
# precisely BECAUSE they are internal. Declare the NARROWEST network containing your target. On a
# single-tenant instance (you are the only one who can subscribe) the exposure is small; on one where
# others can subscribe, it is not.
#
# Refused — and the app will NOT start: 0.0.0.0/0 and ::/0 (the default route: it contains loopback
# and the cloud-metadata address); 169.254.0.0/16 and fe80::/10 (link-local — 169.254.169.254 is your
# instance's credentials); any public CIDR; a bare address with no prefix (10.0.0.0 silently means
# /32, i.e. one address, i.e. nothing). Declarable: subnets of 10/8, 172.16/12, 192.168/16, 100.64/10
# (Tailscale), 127.0.0.0/8 (loopback — allowed, but it warns at boot), fc00::/7, ::1/128.
#
# Full explanation: docs/webhooks.md → "Delivering to a private network".
AETHERCAL_WEBHOOK_PRIVATE_TARGET_CIDRS=

# Free-form environment label surfaced in logs/metadata. e.g. production | staging.
AETHERCAL_ENVIRONMENT=production

# Display name of the app.
AETHERCAL_APP_NAME=AetherCal

# Public base URL of the booking page — used to mint guest cancel/reschedule links. When unset, the
# app falls back to the incoming request's base URL (fine behind a single reverse proxy).
AETHERCAL_BOOKING_BASE_URL=https://book.example.com

# Comma-separated list of ORIGINS allowed to iframe /embed/* (the embeddable widget flow — see
# docs/embedding.md). Blank = "*" (any site can embed it, the wide-open v1 default). Lock this
# down to your known embedding domain(s) once you know them, e.g.
# https://tenant-a.com,https://tenant-b.com. Every OTHER route always denies framing regardless of
# this setting.
AETHERCAL_BOOKING_EMBED_ALLOWED_ORIGINS=

# Comma-separated list of CIDRs for reverse proxies trusted to set CF-Connecting-IP with the real
# guest IP (used by the per-IP rate limiter). Blank = trust NOBODY, so the limiter falls back to
# the raw transport-layer peer address — safe by default, but behind a reverse proxy (the bundled
# compose stack, Cloudflare, NPM) every guest then collapses onto the proxy's one IP and shares a
# single rate-limit budget. Set this to your proxy's concrete CIDR in production.
AETHERCAL_BOOKING_TRUSTED_PROXIES=

# The server-side API key the public booking page presents on the guest's behalf (the guest never
# sees a key). Leave blank at first boot, then issue one with the bundled admin CLI and paste it
# here (single-tenant self-host):
#   docker compose exec app aethercal-admin create-tenant --slug <slug> --name "<name>" --email <addr>
#   docker compose exec app aethercal-admin issue-api-key --tenant-slug <slug> --name <label>
AETHERCAL_API_KEY=

# ============================ SMTP (transactional email + reminders) ============================
# Leave HOST/FROM blank to disable email entirely — the app still boots and bookings still work,
# they just skip the confirmation/reminder emails (graceful degradation).

# SMTP relay hostname. Blank = email disabled.
AETHERCAL_SMTP_HOST=smtp.example.com
# Submission port (587 = STARTTLS, 465 = implicit TLS).
AETHERCAL_SMTP_PORT=587
# SMTP auth username (blank for an unauthenticated relay).
AETHERCAL_SMTP_USERNAME=apikey
# SMTP auth password (blank for an unauthenticated relay).
AETHERCAL_SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
# The default From: address on outgoing mail. Blank = email disabled.
AETHERCAL_SMTP_FROM=bookings@example.com
# Use TLS (STARTTLS on 587, implicit on 465). true|false.
AETHERCAL_SMTP_USE_TLS=true

# ============================ Google Calendar (optional) ============================
# Only needed to connect host Google accounts for busy-check + Meet links. Absent = Google features
# are skipped and the app boots normally (never a hard-fail).

# OAuth client id from your Google Cloud project.
AETHERCAL_GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
# OAuth client secret from your Google Cloud project.
AETHERCAL_GOOGLE_CLIENT_SECRET=CHANGE_ME_GOOGLE_CLIENT_SECRET
# Which calendar the busy-check/events use on a connected account. Usually `primary`.
AETHERCAL_GOOGLE_CALENDAR_ID=primary

# ============================ Bare-metal serve (ignored by the container) ============================
# Only used by the `aethercal-serve` console script when NOT running the container (the container's
# CMD binds 0.0.0.0:8000 explicitly). Publish/change the container's host port via HOST_PORT below.
AETHERCAL_HOST=0.0.0.0
AETHERCAL_PORT=8000

# ============================ docker-compose only (NOT read by the app) ============================
# The PostgreSQL container's BOOTSTRAP superuser — the identity the image initialises the cluster
# with, and the one you run sql/provision_roles.sql as. ==The application never connects as it.== The
# three roles above do, and they are the ones whose passwords go into the three URLs.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_SUPERUSER_PASSWORD
POSTGRES_DB=aethercal
# Host port the API app is published on (maps to container :8000). Keep internal (reverse proxy).
HOST_PORT=8000
# Host port the public booking page is published on (maps to container :5001). The reverse proxy
# forwards book.<domain> here.
BOOKING_HOST_PORT=5001
