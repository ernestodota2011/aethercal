# AetherCal self-host configuration — copy to `.env` and fill in. PLACEHOLDERS ONLY, no real
# secrets in this file. Everything the app reads is an AETHERCAL_* variable (RF-19). The POSTGRES_*
# and HOST_PORT values at the bottom are consumed by docker-compose.yml, not by the app itself.

# ============================ Required ============================

# SQLAlchemy/psycopg URL. With the bundled compose stack the host is the `postgres` service and the
# credentials must match the POSTGRES_* values below.
AETHERCAL_DATABASE_URL=postgresql://aethercal:CHANGE_ME_DB_PASSWORD@postgres:5432/aethercal

# Master secret: signs guest booking tokens AND derives the Fernet key that encrypts stored provider
# credentials. Use a long random value, e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`.
AETHERCAL_APP_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# ============================ Operational toggles ============================

# Run the in-process background scheduler (reminders + webhook delivery + busy-cache refresh) in
# THIS process. Must be ON (1) in EXACTLY ONE process across the whole deploy. The container sets it.
AETHERCAL_RUN_SCHEDULER=1

# Run Alembic migrations automatically on boot. Leave on for the single-unit self-host.
AETHERCAL_AUTO_MIGRATE=1

# Echo every SQL statement to the log (debugging only — noisy). Default off.
AETHERCAL_ECHO_SQL=0

# Free-form environment label surfaced in logs/metadata. e.g. production | staging.
AETHERCAL_ENVIRONMENT=production

# Display name of the app.
AETHERCAL_APP_NAME=AetherCal

# Public base URL of the booking page — used to mint guest cancel/reschedule links. When unset, the
# app falls back to the incoming request's base URL (fine behind a single reverse proxy).
AETHERCAL_BOOKING_BASE_URL=https://book.example.com

# Comma-separated list of ORIGINS allowed to iframe /embed/* (the embeddable widget flow — see
# docs/embedding.md). Blank = "*" (any site can embed it, the wide-open v1 default). Lock this
# down to your known embedding domain(s) once you know them, e.g.
# https://tenant-a.com,https://tenant-b.com. Every OTHER route always denies framing regardless of
# this setting.
AETHERCAL_BOOKING_EMBED_ALLOWED_ORIGINS=

# Comma-separated list of CIDRs for reverse proxies trusted to set CF-Connecting-IP with the real
# guest IP (used by the per-IP rate limiter). Blank = trust NOBODY, so the limiter falls back to
# the raw transport-layer peer address — safe by default, but behind a reverse proxy (the bundled
# compose stack, Cloudflare, NPM) every guest then collapses onto the proxy's one IP and shares a
# single rate-limit budget. Set this to your proxy's concrete CIDR in production.
AETHERCAL_BOOKING_TRUSTED_PROXIES=

# The server-side API key the public booking page presents on the guest's behalf (the guest never
# sees a key). Leave blank at first boot, then issue one with the bundled admin CLI and paste it
# here (single-tenant self-host):
#   docker compose exec app aethercal-admin create-tenant "<name>"
#   docker compose exec app aethercal-admin issue-api-key --tenant "<name>"
AETHERCAL_API_KEY=

# ============================ SMTP (transactional email + reminders) ============================
# Leave HOST/FROM blank to disable email entirely — the app still boots and bookings still work,
# they just skip the confirmation/reminder emails (graceful degradation).

# SMTP relay hostname. Blank = email disabled.
AETHERCAL_SMTP_HOST=smtp.example.com
# Submission port (587 = STARTTLS, 465 = implicit TLS).
AETHERCAL_SMTP_PORT=587
# SMTP auth username (blank for an unauthenticated relay).
AETHERCAL_SMTP_USERNAME=apikey
# SMTP auth password (blank for an unauthenticated relay).
AETHERCAL_SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
# The default From: address on outgoing mail. Blank = email disabled.
AETHERCAL_SMTP_FROM=bookings@example.com
# Use TLS (STARTTLS on 587, implicit on 465). true|false.
AETHERCAL_SMTP_USE_TLS=true

# ============================ Google Calendar (optional) ============================
# Only needed to connect host Google accounts for busy-check + Meet links. Absent = Google features
# are skipped and the app boots normally (never a hard-fail).

# OAuth client id from your Google Cloud project.
AETHERCAL_GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
# OAuth client secret from your Google Cloud project.
AETHERCAL_GOOGLE_CLIENT_SECRET=CHANGE_ME_GOOGLE_CLIENT_SECRET
# Which calendar the busy-check/events use on a connected account. Usually `primary`.
AETHERCAL_GOOGLE_CALENDAR_ID=primary

# ============================ Bare-metal serve (ignored by the container) ============================
# Only used by the `aethercal-serve` console script when NOT running the container (the container's
# CMD binds 0.0.0.0:8000 explicitly). Publish/change the container's host port via HOST_PORT below.
AETHERCAL_HOST=0.0.0.0
AETHERCAL_PORT=8000

# ============================ docker-compose only (NOT read by the app) ============================
# The PostgreSQL container's credentials — MUST match the user/password/db in AETHERCAL_DATABASE_URL.
POSTGRES_USER=aethercal
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=aethercal
# Host port the API app is published on (maps to container :8000). Keep internal (reverse proxy).
HOST_PORT=8000
# Host port the public booking page is published on (maps to container :5001). The reverse proxy
# forwards book.<domain> here.
BOOKING_HOST_PORT=5001
