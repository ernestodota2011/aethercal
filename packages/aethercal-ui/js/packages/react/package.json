{
  "name": "@aethercal/calendar-react",
  "version": "0.1.0",
  "description": "React calendar for AetherCal: month, week, day, list and resource-timeline views with drag-and-drop, theming and i18n, over the headless @aethercal/calendar-core. Ships NO React (peer dependency) and no vendored styles.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "react",
    "calendar",
    "scheduling",
    "timeline",
    "drag-and-drop",
    "booking",
    "aethercal"
  ],
  "homepage": "https://github.com/ernestodota2011/aethercal",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ernestodota2011/aethercal.git",
    "directory": "packages/aethercal-ui/js/packages/react"
  },
  "bugs": "https://github.com/ernestodota2011/aethercal/issues",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "peerDependencies": {
    "react": ">=18.0.0 <20.0.0"
  },
  "dependencies": {
    "@aethercal/calendar-core": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "jsdom": "^25.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.7"
  }
}
