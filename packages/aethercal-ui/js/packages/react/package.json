{
  "name": "@aethercal/calendar-react",
  "version": "0.1.0",
  "description": "React rendering layer for AetherCal: production month view over the headless @aethercal/calendar-core. Ships NO React (peer dependency) and no vendored styles.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["src"],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0 <20.0.0"
  },
  "dependencies": {
    "@aethercal/calendar-core": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "jsdom": "^25.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.7"
  }
}
