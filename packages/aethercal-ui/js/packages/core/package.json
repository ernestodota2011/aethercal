  "files": ["src"],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "fast-check": "^3.23.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.7"
  }
}
