# Normalize line endings: the repository stores text as LF on every platform.
* text=auto eol=lf

# Windows-only tooling that must keep CRLF (none today; placeholder for clarity)
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets (never diffed / normalized)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.whl binary
*.gz binary
*.zip binary
*.ics -text

# Generated / reproducible artifacts: collapse them in GitHub diffs and keep them out of
# textual diffs and code review. They are regenerated (`uv lock`, `pnpm build`), not authored.
uv.lock linguist-generated=true -diff
pnpm-lock.yaml linguist-generated=true -diff
packages/aethercal-ui/src/aethercal/ui/assets/aethercal-calendar.js linguist-generated=true -diff
