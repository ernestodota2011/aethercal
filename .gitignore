# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.pytest_cache/
.ruff_cache/
.hypothesis/
.mypy_cache/
.pyright/

# Coverage
.coverage
.coverage.*
htmlcov/
coverage.xml

# Build artifacts
build/
dist/
*.whl
*.tar.gz

# Virtual environments
.venv/
venv/
env/

# Secrets / instance config (never committed)
.env
.env.*
!.env.example
*.pem
*.key

# Node / JS (packages/aethercal-ui/js) — never commit node_modules or transient build output
node_modules/
*.tsbuildinfo
packages/aethercal-ui/js/dist/
# The built calendar bundle (src/aethercal/ui/assets/aethercal-calendar.js) IS committed on
# purpose: ~3 KB, reproducible via `pnpm build`, and it must be present at import time (rx.asset()
# validates it) for a fresh clone / CI / `pip install` to work with no Node toolchain.

# Reflex build output
.web/

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
# Crisol (internal cross-review tooling): its logs carry local paths and the engine's
# name, and NOTHING internal belongs in a public repo. A pattern, not a list of the
# names we happened to see: `.crisol-reviewed` alone let five `.log` files through.
.crisol-*

# FastHTML's session-cookie SIGNING KEY (fasthtml/core.py::get_key, default key_fname).
# It is generated per deployment and read from disk when the app does not pass
# `secret_key=`. Committing it publishes the key that signs every session cookie the
# booking app issues. It was tracked and PUBLIC until 2026-07-16.
.sesskey
